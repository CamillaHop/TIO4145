# Keep deployments small and deterministic.
# This repo contains large raw course materials; they are NOT needed at runtime.

.git/
.vscode/
.venv/
venv/
__pycache__/
*.pyc
node_modules/
.DS_Store

# Raw materials + prompt templates are not needed on the deployed site.
resources/
context/
prompts/

# This repo contains Python tooling for generating content, but the deployed
# website is static (dist/) + an optional Node serverless function (api/chat.js).
# Excluding these prevents Vercel from trying to treat the project as a Python
# web app.
main.py
pyproject.toml
scripts/**/*.py

# IMPORTANT:
# Do NOT ignore generated/ or web/ — the deployed site fetches JSON from generated/.
